# Secrets — never commit
.env
.env.*
!.env.example

# Stray media dropped in the repo root (screenshots, recordings) —
# never let a blanket `git add -A` sweep these into a public repo.
/*.jpg
/*.jpeg
/*.png
/*.gif
/*.mp4
/*.mkv
/*.webm

# Data
data/
*.db
*.sqlite3

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors
.idea/
.vscode/
*.swp
