# hackQueue configuration — copy to `.env` and fill in.
# NEVER commit your real .env (it is gitignored).

# ── Required ────────────────────────────────────────────────────────────────

# Discord bot token.
# Get one: https://discord.com/developers/applications → your app → Bot → Reset Token.
# No privileged intents are required.
DISCORD_TOKEN=

# ── Platform tokens (each optional — the matching platform is disabled if unset) ──

# Hack The Box "App Token".
# Get one: https://app.hackthebox.com → your profile → Profile Settings →
# "Create App Token". NOTE: tokens expire (max 1 year); /health warns when
# HTB polling starts failing with auth errors.
HTB_APP_TOKEN=

# Root-Me API key.
# Get one: log in at https://www.root-me.org → Preferences
# (https://www.root-me.org/?page=preferences) → API key.
ROOTME_API_KEY=

# TryHackMe needs no token — its public endpoints are unauthenticated
# (and best-effort; see README "TryHackMe reliability").

# ── Storage ─────────────────────────────────────────────────────────────────

# SQLAlchemy async URL. Default is a SQLite file under ./data/.
# For Postgres: postgresql+asyncpg://user:pass@host:5432/hackqueue
# (install with: pip install 'hackqueue[postgres]')
DATABASE_URL=sqlite+aiosqlite:///data/hackqueue.db

# ── Web leaderboard (optional) ──────────────────────────────────────────────

# Serve the web leaderboard (NeatQueue-style public board).
# Servers still opt in individually with /config web on — nothing is published
# until a moderator turns it on there.
WEB_ENABLED=false

# Address the bot binds. 0.0.0.0 is right inside Docker; use 127.0.0.1 if you
# put a reverse proxy in front of it on the same host.
WEB_HOST=0.0.0.0
WEB_PORT=8080

# The URL the board is reachable at from the outside. This is what /config web
# hands to moderators, so set it to your real domain when behind a proxy,
# e.g. https://boards.example.com
WEB_BASE_URL=http://localhost:8080

# ── Tuning (all optional) ───────────────────────────────────────────────────

# Path to the scoring/claims config file.
SCORING_CONFIG=scoring.toml

# Per-platform poll intervals, in minutes.
POLL_INTERVAL_HTB=45
POLL_INTERVAL_THM=60
POLL_INTERVAL_ROOTME=60

# How often to refresh the box catalog (HTB machines + IppSec dataset), in hours.
CATALOG_REFRESH_HOURS=24

# Logging: DEBUG | INFO | WARNING | ERROR. LOG_FORMAT: pretty | json
LOG_LEVEL=INFO
LOG_FORMAT=pretty
